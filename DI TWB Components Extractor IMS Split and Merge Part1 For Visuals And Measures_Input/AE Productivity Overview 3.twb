      <column caption="Calculation8" datatype="real" name="[Calculation_1485061991622422530]" role="measure" type="quantitative">
        <calculation class="tableau" formula="DATETRUNC('month', [eventDate]) = MONTH([Calculation_49258170865287169])" />
      </column>
      <column caption="Patient Days CD" datatype="integer" name="[Calculation_1508142926654320640]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [episodeStatus] = 'discharged' then [Calculation_1201335260471140365] ELSEif [patientStatus] = 'active' then TODAY()-[Discharge Date (copy)_17170025692839938]+1 END" />
      </column>
      <column caption="LOS CD" datatype="real" name="[Calculation_1508142926657191939]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Calculation_1508142926654320640])/[# of Admits (copy)_1201335260475002894]" />
      </column>
      <column caption="Calculation7" datatype="real" name="[Calculation_1508142926658985988]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [eventDate] = yest" />
      </column>
      <column caption="Census Prior Day" datatype="integer" name="[Calculation_1508142926659080197]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [eventDate] = [Calculation_2364952800433098761] then [census] END" />
      </column>
      <column caption="Monday Current Month test" datatype="boolean" name="[Calculation_1511239213619892224]" role="dimension" type="nominal">
        <calculation class="tableau" formula="DATEDIFF('month',[eventDate],TODAY()) = 0" />
      </column>
      <column caption="Monday current month datepart test" datatype="boolean" name="[Calculation_1511239213620269057]" role="dimension" type="nominal">
        <calculation class="tableau" formula="DATEPART('weekday',[eventDate]) = 2" />
      </column>
      <column caption="countd event date test" datatype="integer" name="[Calculation_1511239213621612546]" role="measure" type="quantitative">
        <calculation class="tableau" formula="COUNTD([eventDate])" />
      </column>
      <column caption="Discharge LOS" datatype="integer" default-format="n#,##0;-#,##0" name="[Calculation_1516587202381398025]" role="measure" type="quantitative" visual-totals="Avg">
        <calculation class="tableau" formula="IF [eventType] = 'discharge' then DATEDIFF('day', [admissionDate],[Calculation_17170025691844608])+1 END" />
      </column>
      <column caption="ALOS 2" datatype="real" name="[Calculation_152559478159355905]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Calculation_1043990738244882432])*(AVG([Days Gone in Month ADC (copy 2)_152559478161006594])/[# of Admits (copy)_1201335260475002894])" />
      </column>
      <column caption="Date View" datatype="date" name="[Calculation_1530660946343661569]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="[Parameters].[Event Date Parameter 2]" />
      </column>
      <column caption="Infotip" datatype="string" name="[Calculation_1534320105526075392]" role="dimension" type="nominal">
        <calculation class="tableau" formula="&quot;info&quot;" />
      </column>
      <column caption="Calculation6" datatype="boolean" name="[Calculation_157625995359461411]" role="measure" type="nominal">
        <calculation class="tableau" formula="LAST()=0">
          <table-calc ordering-type="Rows" />
        </calculation>
      </column>
      <column caption="Yesterday Test" datatype="datetime" name="[Calculation_1704612466823258113]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="DATEADD('day',-1,TODAY())" />
      </column>
      <column caption="Testing" datatype="boolean" name="[Calculation_1704612466826072067]" role="dimension" type="nominal">
        <calculation class="tableau" formula="[eventDate]&gt;=dateadd('day',-1,datetrunc('week', today()))&#13;&#10;&#13;&#10;and&#13;&#10;&#13;&#10;[eventDate]&lt;datetrunc('day',today())" />
      </column>
      <column caption="Testing 2" datatype="boolean" name="[Calculation_1704612466826399748]" role="dimension" type="nominal">
        <calculation class="tableau" formula="[eventDate]&lt;=[Parameters].[Event Date Parameter 2]" />
      </column>
      <column caption="Death Rate Projection" datatype="real" name="[Calculation_1704612466837983240]" role="measure" type="quantitative">
        <calculation class="tableau" formula="[Live Discharge MTD Projection   (copy)_2146528180508065795]/SUM([Calculation_1043990738244882432])" />
      </column>
      <column caption="Controllable Non-Admit?" datatype="string" name="[Calculation_1707427247391567873]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF [referralDispositionReasonDesc] = 'OUT OF AREA - REFERRED EXTERNALLY' then &quot;Uncontrollable NONADM&quot;&#13;&#10;ELSEIF [referralDispositionReasonDesc] = 'HOS - REFERRED TO HOME HEALTH' then &quot;Uncontrollable NONADM&quot;&#13;&#10;ELSEIF [referralDispositionReasonDesc] = 'PAYOR NO CONTRACT - COMMERCIAL' then &quot;Uncontrollable NONADM&quot;&#13;&#10;ELSEIF [referralDispositionReasonDesc] = 'INTAKE - PAYOR NO CONTRACT - COMMERCIAL' then &quot;Uncontrollable NONADM&quot;&#13;&#10;ELSEIF [referralDispositionReasonDesc] = 'PAYOR NO CONTRACT - MEDICARE REPLACEMENT' then &quot;Uncontrollable NONADM&quot;&#13;&#10;ELSEIF [referralDispositionReasonDesc] = 'NO PAYOR SOURCE' then &quot;Uncontrollable NONADM&quot;&#13;&#10;ELSE &quot;Controllable NONADM&quot; END" />
      </column>
      <column caption="Discharge Date" datatype="date" name="[Calculation_17170025691844608]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="IF [eventSubType] = &quot;Live Discharge&quot; or [eventSubType] = &quot;Other Discharge&quot; &#13;&#10;THEN&#13;&#10;[eventDate]&#13;&#10;END" />
      </column>
      <column caption="Discharges" datatype="integer" name="[Calculation_17170025692258305]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [eventType] = &quot;Discharge&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END" />
      </column>
      <column caption="Current Month LOS" datatype="real" name="[Calculation_17170025693216771]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Calculation_1201335260862726171])/SUM([Current Month Referrals (copy)_1201335261169856544])" />
      </column>
      <column caption="Days in Month RR" datatype="integer" name="[Calculation_1733041435180294144]" role="measure" type="quantitative">
        <calculation class="tableau" formula="DATEPART('day', DATEADD('day', -1, DATEADD('month', 1, DATETRUNC('month', [eventDate] )  ) ) )" />
      </column>
      <column caption="Gone in month (copy)" datatype="integer" name="[Calculation_1733041435180449793]" role="measure" type="quantitative">
        <calculation class="tableau" formula="If MONTH([eventDate])=MONTH([Parameters].[Event Date Parameter 2]) then [Calculation_2364952800436817930] else [Calculation_1733041435180294144] END" />
      </column>
      <column caption="Relative Date Filter with Anchor" datatype="boolean" name="[Calculation_1733041435464384514]" role="dimension" type="nominal">
        <calculation class="tableau" formula="DATEDIFF('month',[AEhiredate],[eventDate]) &gt;= 6" />
      </column>
      <column caption="Calls Projection" datatype="real" name="[Calculation_1733041435466457091]" role="measure" type="quantitative">
        <calculation class="tableau" formula="[callcount]/[Calculation_2364952800436817930]*[Calculation_2364952800436912139]" />
      </column>
      <column caption="Count of Patients" datatype="integer" name="[Calculation_1740359848285077504]" role="measure" type="quantitative">
        <calculation class="tableau" formula="COUNTD([patientId])" />
      </column>
      <column caption="Count of Episodes" datatype="integer" name="[Calculation_1740359848285462529]" role="measure" type="quantitative">
        <calculation class="tableau" formula="COUNTD([episodeid])" />
