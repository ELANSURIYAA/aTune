            <column caption="AE Tenure" datatype="integer" name="[Calculation_1740359848650784773]" role="measure" type="quantitative">
              <calculation class="tableau" formula="DATEDIFF('month',[AEhiredate], [Calculation_49258170865287169])" />
            </column>
            <column caption="# of Admits" datatype="integer" default-format="n#,##0;-#,##0" name="[Calculation_2364952800380751872]" role="measure" type="quantitative">
              <calculation class="tableau" formula="SUM([Calculation_760826876183662595])+SUM([# of Admits (copy)_1508142926664663047])" />
            </column>
            <column caption="# of Referrals" datatype="integer" default-format="n#,##0;-#,##0" name="[Calculation_363384242383106049]" role="measure" type="quantitative">
              <calculation class="tableau" formula="IF [eventType] = &quot;Referrals&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END" />
            </column>
            <column caption="Today" datatype="date" name="[Calculation_49258170865287169]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="TODAY()" />
            </column>
            <column caption="Start of Month Date" datatype="datetime" name="[Calculation_562105586989146113]" role="dimension" type="quantitative">
              <calculation class="tableau" formula="DATETRUNC('month',[eventDate])" />
            </column>
            <column caption="End of Month Date" datatype="datetime" name="[Calculation_562105586994315269]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="DATEADD('day', -1, DATEADD('month', 1, DATETRUNC('month', [eventDate])))" />
            </column>
            <column caption="Event Date Weekday (Start of Month)" datatype="datetime" name="[Calculation_562105586994425862]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="IF DATEPART('weekday', [Calculation_562105586989146113]) = 1&#13;&#10;THEN DATEADD('day', 1, [Calculation_562105586989146113])&#13;&#10;ELSEIF DATEPART('weekday', [Calculation_562105586989146113]) = 7&#13;&#10;THEN DATEADD('day', 2, [Calculation_562105586989146113])&#13;&#10;ELSE [Calculation_562105586989146113]&#13;&#10;END" />
            </column>
            <column caption="# of Weekdays" datatype="integer" name="[Calculation_562105586995085321]" role="measure" type="quantitative">
              <calculation class="tableau" formula="MIN(&#13;&#10;DATEDIFF('day', [Calculation_562105586994425862], [Event Date Weekday (Start of Month) (copy)_562105586994962440])&#13;&#10;+ 1&#13;&#10;- 2 * DATEDIFF('week', [Calculation_562105586994425862], [Event Date Weekday (Start of Month) (copy)_562105586994962440])&#13;&#10;)" />
            </column>
            <column caption="Unsynced Admits" datatype="integer" name="[Calculation_760826876183662595]" role="measure" type="quantitative">
              <calculation class="tableau" formula="IF [visitType]='HOSPICE SOC' AND [eventType]='SCHEDULEDVISIT' and [eventSubType] = 'INCOMPLETE' OR [visitType]='HOSPICE SOC' AND [eventType]='SCHEDULEDVISIT' AND [eventSubType]= 'LATE'&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END" />
            </column>
            <column caption="Admits % to Quota" datatype="real" name="[Calculation_907193912380518414]" role="measure" type="quantitative">
              <calculation class="tableau" formula="ZN([Calculation_2364952800380751872]/[Calculation_1352768752524439552])" />
            </column>
            <column caption="Event Date Weekday (End of Month)" datatype="datetime" name="[Event Date Weekday (Start of Month) (copy)_562105586994962440]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="IF DATEPART('weekday', [Calculation_562105586994315269]) = 1&#13;&#10;THEN DATEADD('day', 1, [Calculation_562105586994315269])&#13;&#10;ELSEIF DATEPART('weekday', [Calculation_562105586994315269]) = 7&#13;&#10;THEN DATEADD('day', 2, [Calculation_562105586994315269])&#13;&#10;ELSE [Calculation_562105586994315269]&#13;&#10;END" />
            </column>
