        <calculation class="tableau" formula="IF [admissionCoordName] = 'CLEMENT, HEATHER'&#13;&#10;or [admissionCoordName] = 'DOMINGUEZ, TERI'&#13;&#10;or [admissionCoordName] = 'GLOVER, JAKE'&#13;&#10;or [admissionCoordName] = 'LANCE, ANGELA'&#13;&#10;or [admissionCoordName] = 'LAPOINTE, AMY'&#13;&#10;or [admissionCoordName] = 'LYDY, JEN'&#13;&#10;or [admissionCoordName] = 'MARSHALL, CATHERINE'&#13;&#10;or [admissionCoordName]= 'MARSICO, JACKIE'&#13;&#10;or [admissionCoordName]='MITCHELL, DIANE'&#13;&#10;or [admissionCoordName]= 'MORRISSEY, MARIBETH'&#13;&#10;or [admissionCoordName] ='MULL, COLLENE'&#13;&#10;or [admissionCoordName] ='SLOCUM, JESSICA'&#13;&#10;or [admissionCoordName] ='TAYLOR, HEATHER'&#13;&#10;or [admissionCoordName] ='VANDEUSEN, BRANDI'&#13;&#10;or [admissionCoordName] ='WEIST, CAROLYN'&#13;&#10;or [admissionCoordName] ='WETZEL, STACEY'&#13;&#10;or [admissionCoordName] = 'BRATCHER, JAIME'&#13;&#10;or [admissionCoordName] = 'GOBLE, KIMBERLY'&#13;&#10;or [admissionCoordName] = 'CARRILLO, JUVE'&#13;&#10;OR [admissionCoordName] = 'SCHNURR, NICHOLE'&#13;&#10;or [admissionCoordName] = 'BRIDWELL, KRISTA'&#13;&#10;or [admissionCoordName] = 'TAYLOR, DANIELLE'&#13;&#10;or [admissionCoordName] = 'THOMAS HOFFMAN, KELLY'&#13;&#10;or [admissionCoordName] = 'WHIPPLE, CARRIE'&#13;&#10;or [admissionCoordName] = 'NONE ASSIGNED,'&#13;&#10;or [admissionCoordName] = 'null'&#13;&#10;or [admissionCoordName] = 'ROGERS, KAYLA'&#13;&#10;then &quot;exclude AE&quot; END" />
      </column>
      <column caption="AVP" datatype="string" name="[Calculation_1352768752536981507]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF [providerbranchState] = 'mi' then 'Bert Valdez'&#13;&#10;elseif [providerbranchState] = 'in' then 'Colleen Mull' &#13;&#10;ELSEIF [providerbranchState] = 'il' or [providerbranchState] = 'ma' then 'James Szmanksi'&#13;&#10;ELSEif [providerbranchState] = 'oh' then 'Steven Trapp'&#13;&#10;elseif [providerbranchState] = 'ok'  and [Calculation_1419478311167176718] = 'ada' or [Calculation_1419478311167176718] = 'ACK/AOK' or [Calculation_1419478311167176718] = 'adt' or [Calculation_1419478311167176718] = 'ahg' or [Calculation_1419478311167176718] = 'aib' or [Calculation_1419478311167176718] = 'alw' or [Calculation_1419478311167176718] = 'ard' or [Calculation_1419478311167176718] = 'asw' or [Calculation_1419478311167176718] = 'ren' then 'Jessica Stanley'&#13;&#10;ELSEIF [providerbranchState] = 'la' then 'Jessica Stanley'&#13;&#10;elseif [providerbranchState] = 'tx' and [Calculation_1419478311167176718] = 'elp' then 'Jessica Stanley'&#13;&#10;ELSEIF [providerbranchState] = 'tx' and [Calculation_1419478311167176718] = 'crp' or [Calculation_1419478311167176718] = 'ctx' or [Calculation_1419478311167176718] = 'rgv' or [Calculation_1419478311167176718] = 'sat' then 'Jake Glover' &#13;&#10;ELSEIF [providerbranchState] = 'tx' and [Calculation_1419478311167176718] = 'cle' or [Calculation_1419478311167176718] = 'grp' or [Calculation_1419478311167176718] = 'klh' or [Calculation_1419478311167176718] = 'rtx' or [Calculation_1419478311167176718] = 'txk' then 'Lindsay Webber'&#13;&#10;ELSEIF [providerbranchState] = 'ks' or [providerbranchState] = 'mo' then 'Lindsey Childress'&#13;&#10;ELSEIF [providerbranchState] = 'ok' and [Calculation_1419478311167176718] = 'mus' or [Calculation_1419478311167176718] = 'sal' then 'Lindsey Childress' END" />
