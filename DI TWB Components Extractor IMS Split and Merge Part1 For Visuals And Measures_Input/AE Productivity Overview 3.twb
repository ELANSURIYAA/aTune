      </column>
      <column caption="Current Month?" datatype="boolean" name="[Calculation_1244400876976672768]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF MONTH([eventDate]) = MONTH(TODAY()) then TRUE else FALSE end" />
      </column>
      <column caption="Projections" datatype="real" name="[Calculation_1302103286417338368]" role="measure" type="quantitative">
        <calculation class="tableau" formula="[Calculation_1228356805761007656]+[Saturday Projection (copy)_157625995338993681]+[Sunday Projection  (copy)_157625995340120084]+[Sunday Projection  (copy)_157625995341594647]+[Tuesday Projection   (copy)_157625995345055770]+[Wednesday Projection   (copy)_157625995346264095]+[Tuesday Projection   (copy)_157625995347931170]" />
