      <column caption="Amal Test Previous Month" datatype="integer" name="[Amal Test (copy)_1225823585577402397]" role="measure" type="quantitative">
        <calculation class="tableau" formula="if [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&lt; [start of month (copy)_1201335260863078428] and [dischargeDate]&gt; [start of month (copy)_1201335260863078428] and [dischargeDate] &lt; [Calculation_1201335260515913746] then DATEDIFF('day',[start of month (copy)_1201335260863078428],dischargeDate)+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&lt; [start of month (copy)_1201335260863078428] and isnull([dischargeDate])=TRUE then DATEDIFF('day',[start of month (copy)_1201335260863078428],[Calculation_1201335260515913746])+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&gt; [start of month (copy)_1201335260863078428] and [Discharge Date (copy)_17170025692839938] &lt; [Calculation_1201335260515913746] and isnull(dischargeDate)=TRUE then DATEDIFF('day',[Discharge Date (copy)_17170025692839938],[Calculation_1201335260515913746])+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&gt; [start of month (copy)_1201335260863078428] and isnull(dischargeDate)=FALSE then DATEDIFF('day',[Discharge Date (copy)_17170025692839938], [dischargeDate])+1&#13;&#10;else 0&#13;&#10;END" />
      </column>
      <column caption="Amal Test any Event Date" datatype="integer" name="[Amal Test (copy)_1225823585909493810]" role="measure" type="quantitative">
        <calculation class="tableau" formula="if [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&lt; [start of month (copy)_1225823585909358641] and [dischargeDate]&gt; [start of month (copy)_1225823585909358641] then DATEDIFF('day',[start of month (copy)_1225823585909358641],dischargeDate)+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&lt; [start of month (copy)_1225823585909358641] and isnull([dischargeDate])=TRUE then DATEDIFF('day',[start of month (copy)_1225823585909358641],[Calculation_1225823585910222899])+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&gt; [start of month (copy)_1225823585909358641] and isnull(dischargeDate)=TRUE then DATEDIFF('day',[Discharge Date (copy)_17170025692839938],[Calculation_1225823585910222899])+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&gt; [start of month (copy)_1225823585909358641] and isnull(dischargeDate)=FALSE then DATEDIFF('day',[Discharge Date (copy)_17170025692839938], [dischargeDate])+1&#13;&#10;else 0&#13;&#10;END&#13;&#10;&#13;&#10;//This formula won't work for the current month.  It will calculate patient days through the End of current month rgardless what today's day is.  Look at doing a MIN of today versus end of month to calc current month correctly" />
      </column>
