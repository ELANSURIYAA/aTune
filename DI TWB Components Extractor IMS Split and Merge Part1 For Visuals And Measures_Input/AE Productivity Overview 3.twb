        <calculation class="tableau" formula="IF   [LOS (copy)_1012184072929411072] &lt;=7 and&#13;&#10;[LOS (copy)_1012184072929411072] &gt;= 0 &#13;&#10;THEN &quot;1 to 7 Days&quot;&#13;&#10;ELSE&#13;&#10;&quot;&gt; 7 Days&quot;&#13;&#10;END" />
      </column>
      <column caption="LOS Days" datatype="integer" name="[Calculation_1201335260471140365]" role="measure" type="quantitative">
        <calculation class="tableau" formula="DATEDIFF('day', [Discharge Date (copy)_17170025692839938],[Calculation_17170025691844608])+1" />
      </column>
      <column caption="Patient Days Start Date of Month" datatype="datetime" name="[Calculation_1201335260511076367]" role="dimension" type="quantitative">
        <calculation class="tableau" formula="IF [admissionDate]&#13;&#10;&lt;[Calculation_1201335260515913746] &#13;&#10;THEN [Calculation_1201335260515913746]&#13;&#10;&#13;&#10;ELSE&#13;&#10;[admissionDate]&#13;&#10;END" />
      </column>
      <column caption="start of month" datatype="datetime" name="[Calculation_1201335260515913746]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="DATETRUNC('month',TODAY())" />
      </column>
      <column caption="Patient Days MTD" datatype="integer" name="[Calculation_1201335260519387155]" role="measure" type="quantitative">
        <calculation class="tableau" formula="DATEDIFF('day',[Calculation_1201335260511076367],TODAY())+1" />
      </column>
      <column caption="Patient Days" datatype="integer" name="[Calculation_1201335260532228118]" role="measure" type="quantitative">
        <calculation class="tableau" formula="if [eventType]= 'discharge' THEN [Calculation_17170025691844608]-[Discharge Date (copy)_17170025692839938]+1 END" />
      </column>
      <column caption="Patient Days End Date" datatype="date" name="[Calculation_1201335260538363928]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="IF [dischargeDate]&lt;TODAY() AND  [dischargeDate] &gt; [Calculation_1201335260515913746]&#13;&#10;THEN [dischargeDate]&#13;&#10;elseif [dischargeDate] &lt; [Calculation_1201335260515913746]&#13;&#10;THEN&#13;&#10;NULL&#13;&#10;ELSE TODAY()&#13;&#10;END" />
      </column>
      <column caption="Patient Day MTD 2" datatype="integer" name="[Calculation_1201335260539478041]" role="measure" type="quantitative">
        <calculation class="tableau" formula="DATEDIFF('day',[Calculation_1201335260511076367],[Calculation_1201335260538363928])+1" />
      </column>
      <column caption="Patient days MTd" datatype="real" name="[Calculation_1201335260539797530]" role="measure" type="quantitative">
        <calculation class="tableau" formula="ABS([Calculation_1201335260538363928]-[Calculation_1201335260511076367])+1" />
      </column>
      <column caption="Patient Days MTD 2" datatype="integer" name="[Calculation_1201335260862726171]" role="measure" type="quantitative">
        <calculation class="tableau" formula="if [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [admissionDate]&lt; [Calculation_1201335260515913746] and [dischargeDate]&gt; [Calculation_1201335260515913746] then DATEDIFF('day',[Calculation_1201335260515913746],dischargeDate)+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [admissionDate]&lt; [Calculation_1201335260515913746] and isnull([dischargeDate])=TRUE then DATEDIFF('day',[Calculation_1201335260515913746],TODAY())+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [admissionDate]&gt; [Calculation_1201335260515913746] and isnull(dischargeDate)=TRUE then DATEDIFF('day',[admissionDate],TODAY())+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [admissionDate]&gt; [Calculation_1201335260515913746] and isnull(dischargeDate)=FALSE then DATEDIFF('day',[admissionDate], [dischargeDate])+1&#13;&#10;else 0&#13;&#10;END" />
      </column>
      <column caption="Last Day of Previous Month" datatype="date" name="[Calculation_1201335260867346463]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="DATE(DATETRUNC('month',TODAY() )-1)" />
      </column>
      <column caption="ALOS % to Prior Month" datatype="real" name="[Calculation_1225823585178750978]" role="measure" type="quantitative">
        <calculation class="tableau" formula="[Calculation_1225823585573560347]/[Patient days/Discharges (copy)_1225823585607602207]" />
      </column>
      <column caption="med LOS current month" datatype="real" name="[Calculation_1225823585203027979]" role="measure" type="quantitative">
        <calculation class="tableau" formula="MEDIAN([Current Month LOS (copy)_1225823585177649152])" />
      </column>
      <column caption="MED LOS % to Budget" datatype="real" name="[Calculation_1225823585210454031]" role="measure" type="quantitative">
        <calculation class="tableau" formula="MEDIAN([LOS (copy)_1012184072929411072])/AVG([federated.1jf0fxd1gq0u0w171fect16mur10].[Budgeted Median LOS])" />
      </column>
      <column caption="LOS &lt; 7 Days Current Month" datatype="integer" name="[Calculation_1225823585213755408]" role="measure" type="quantitative">
        <calculation class="tableau" formula="if [Previous Month LOS 2 (copy)_1225823585209061389] &lt; 8 &#13;&#10;THEN&#13;&#10;&#13;&#10;[Previous Month LOS 2 (copy)_1225823585209061389]&#13;&#10;ELSE&#13;&#10;0&#13;&#10;END" />
      </column>
      <column caption="Patient Days &lt; 7" datatype="string" name="[Calculation_1225823585217548305]" role="measure" type="nominal">
        <calculation class="tableau" formula="IF  MAX([Calculation_1201335260471140365])&lt;8&#13;&#10;THEN &quot;LOS&lt; 7&quot;&#13;&#10;ELSE&quot;LOS &gt; 7&quot;&#13;&#10;END" />
      </column>
      <column caption="Amal Test" datatype="integer" name="[Calculation_1225823585271554066]" role="measure" type="quantitative">
        <calculation class="tableau" formula="if [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&lt; [Calculation_1201335260515913746] and [dischargeDate]&gt; [Calculation_1201335260515913746] then DATEDIFF('day',[Calculation_1201335260515913746],dischargeDate)+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&lt; [Calculation_1201335260515913746] and isnull([dischargeDate])=TRUE then DATEDIFF('day',[Calculation_1201335260515913746],TODAY())+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&gt; [Calculation_1201335260515913746] and isnull(dischargeDate)=TRUE then DATEDIFF('day',[Discharge Date (copy)_17170025692839938],TODAY())+1&#13;&#10;elseif [elaraServiceLine] = 'HOSPICE'&#13;&#10;and [Discharge Date (copy)_17170025692839938]&gt; [Calculation_1201335260515913746] and isnull(dischargeDate)=FALSE then DATEDIFF('day',[Discharge Date (copy)_17170025692839938], [dischargeDate])+1&#13;&#10;else 0&#13;&#10;END" />
      </column>
      <column caption="CountD Discharge" datatype="integer" name="[Calculation_1225823585274310675]" role="measure" type="quantitative">
        <calculation class="tableau" formula="COUNTD([dischargeId])" />
      </column>
      <column caption="Patient days/Discharges" datatype="real" name="[Calculation_1225823585573560347]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Calculation_1225823585271554066])/SUM([Current Month Referrals (copy)_1201335261169856544])" />
      </column>
      <column caption="LOS &lt; 7 % to PRior" datatype="real" name="[Calculation_1225823585620934692]" role="measure" type="quantitative">
        <calculation class="tableau" formula="COUNT([Current Month LOS (copy)_1225823585177649152])/COUNT([Current Month LOS 3 (copy)_1225823585560625177])" />
      </column>
      <column caption="Previous Month # of AE" datatype="integer" name="[Calculation_1225823585631293480]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="IF [eventDate]&gt;=[start of month (copy)_1201335260863078428] AND [eventDate]&lt;[Calculation_1201335260515913746]&#13;&#10;THEN [admissionCoordId]&#13;&#10;END" />
      </column>
      <column caption="Countd # of AE" datatype="integer" name="[Calculation_1225823585632071721]" role="measure" type="quantitative">
        <calculation class="tableau" formula="COUNTD([# of AEs (copy)_49258170980130849])" />
      </column>
      <column caption="Admits/AE Prior Month" datatype="real" name="[Calculation_1225823585636388908]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Calculation_2364952800383918081])/COUNTD([Calculation_1225823585631293480])" />
      </column>
      <column caption="Last  Day of Month any Event Date" datatype="datetime" name="[Calculation_1225823585910222899]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="DATEADD('second',-1,DATEADD('month',1,DATETRUNC('month',[eventDate])))" />
      </column>
      <column caption="LOS 2 " datatype="integer" name="[Calculation_1225823586256478261]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [dischargeDate]=[eventDate]&#13;&#10;THEN&#13;&#10;(([dischargeDate]-[Discharge Date (copy)_17170025692839938])+1)&#13;&#10;END" />
      </column>
      <column caption="LOS &lt; 7 Count" datatype="integer" name="[Calculation_1225823586261270582]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [Calculation_1201335260209541128]=&quot;1 to 7 Days&quot;&#13;&#10;THEN&#13;&#10;1&#13;&#10;else 0&#13;&#10;END" />
