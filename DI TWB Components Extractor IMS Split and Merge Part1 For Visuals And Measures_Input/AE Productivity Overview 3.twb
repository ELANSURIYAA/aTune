      <column caption="Sunday Remaining" datatype="integer" name="[Calculation_1228356805749518352]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Weekday Count Monday Thus Far    (copy)_1228356805749018638])-SUM([Weekday Count Tuesday Gone in Month 1 (copy) (copy) (copy) (copy) (copy)_2417870060999880710])" />
