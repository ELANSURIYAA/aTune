          </datasources>
          <datasource-dependencies datasource="sqlproxy.0tnoyhj1kuyfny18m8zc80otdqxm">
            <column caption="# of Admits (no unsynced)" datatype="integer" default-format="n#,##0;-#,##0" name="[# of Admits (copy)_1508142926664663047]" role="measure" type="quantitative">
              <calculation class="tableau" formula="IF [eventType] = 'ADMISSION' THEN 1 ELSE 0 END" />
            </column>
            <column aggregation="Year" caption="AE Hire Date" datatype="date" default-type="ordinal" layered="true" name="[AEhiredate]" pivot="key" role="dimension" type="ordinal" user-datatype="date" visual-totals="Default" />
            <column aggregation="Year" caption="A Etermdate" datatype="date" default-type="ordinal" layered="true" name="[AEtermdate]" pivot="key" role="dimension" type="ordinal" user-datatype="date" visual-totals="Default" />
            <column caption="HCHB Quota" datatype="integer" name="[Calculation_1352768752524439552]" role="measure" type="quantitative">
              <calculation class="tableau" formula="ZN(SUM([budgetAdmits]))" />
            </column>
            <column caption="AEs to Exclude 2" datatype="string" name="[Calculation_1352768752532533249]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF [admissionCoordName] = 'CLEMENT, HEATHER'&#13;&#10;or [admissionCoordName] = 'DOMINGUEZ, TERI'&#13;&#10;or [admissionCoordName] = 'GLOVER, JAKE'&#13;&#10;or [admissionCoordName] = 'LANCE, ANGELA'&#13;&#10;or [admissionCoordName] = 'LAPOINTE, AMY'&#13;&#10;or [admissionCoordName] = 'LYDY, JEN'&#13;&#10;or [admissionCoordName] = 'MARSHALL, CATHERINE'&#13;&#10;or [admissionCoordName]= 'MARSICO, JACKIE'&#13;&#10;or [admissionCoordName]='MITCHELL, DIANE'&#13;&#10;or [admissionCoordName]= 'MORRISSEY, MARIBETH'&#13;&#10;or [admissionCoordName] ='MULL, COLLENE'&#13;&#10;or [admissionCoordName] ='SLOCUM, JESSICA'&#13;&#10;or [admissionCoordName] ='TAYLOR, HEATHER'&#13;&#10;or [admissionCoordName] ='VANDEUSEN, BRANDI'&#13;&#10;or [admissionCoordName] ='WEIST, CAROLYN'&#13;&#10;or [admissionCoordName] ='WETZEL, STACEY'&#13;&#10;or [admissionCoordName] = 'BRATCHER, JAIME'&#13;&#10;or [admissionCoordName] = 'GOBLE, KIMBERLY'&#13;&#10;or [admissionCoordName] = 'CARRILLO, JUVE'&#13;&#10;OR [admissionCoordName] = 'SCHNURR, NICHOLE'&#13;&#10;or [admissionCoordName] = 'BRIDWELL, KRISTA'&#13;&#10;or [admissionCoordName] = 'TAYLOR, DANIELLE'&#13;&#10;or [admissionCoordName] = 'THOMAS HOFFMAN, KELLY'&#13;&#10;or [admissionCoordName] = 'WHIPPLE, CARRIE'&#13;&#10;or [admissionCoordName] = 'NONE ASSIGNED,'&#13;&#10;or [admissionCoordName] = 'null'&#13;&#10;or [admissionCoordName] = 'ROGERS, KAYLA'&#13;&#10;then &quot;exclude AE&quot; END" />
            </column>
            <column caption="Branch  " datatype="string" name="[Calculation_1419478311167176718]" role="dimension" type="nominal">
              <calculation class="tableau" formula="if [providerbranchcode] = 'AOK' or [providerbranchcode] = 'ACK' then &quot;ACK/AOK&quot; &#13;&#10;ELSEIF [providerbranchcode] = 'FOH' or [providerbranchcode] = 'FTW' then &quot;FOH/FTW&quot; else [providerbranchcode] END" />
            </column>
